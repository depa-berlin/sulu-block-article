{
    "name": "depa/sulu-block-article",
    "description": "Article block collection for Sulu CMS (headings, text, image, list, blockquote, and more)",
    "type": "symfony-bundle",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "symfony/framework-bundle": "^7.0",
        "depa/sulu-block-helper": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-symfony": "^2.0"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/depa-berlin/sulu-block-helper"
        }
    ],
    "autoload": {
        "psr-4": {
            "Depa\\SuluBlockArticleBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Depa\\SuluBlockArticleBundle\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
