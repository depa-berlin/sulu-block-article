<?xml version="1.0" ?>
<template xmlns="http://schemas.sulu.io/template/template"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">
    <key>block--article-h2</key>
    <meta>
        <title lang="en">Headline (H2)</title>
        <title lang="de">Überschrift (H2)</title>
    </meta>
    <properties>
        <property name="text" type="text_line">
            <!-- @see https://docs.sulu.io/en/2.2/book/extend-admin.html#selection-field-type -->
            <meta>
                <title lang="en">Title</title>
                <title lang="de">Überschrift</title>
            </meta>
        </property>
        <section name="config">
            <meta>
                <title lang="en">Config</title>
                <title lang="de">Einstellungen</title>
            </meta>
            <properties>

                <property name="table_of_contents" type="checkbox">

                    <params>
                        <param name="type" value="toggler"/>
                        <param name="default_value" value="false"/>
                        <param name="label">
                            <meta>
                                <title lang="en">In Inhaltsverzeichnis aufnehmen</title>
                                <title lang="de">In Inhaltsverzeichnis aufnehmen</title>
                            </meta>
                        </param>
                    </params>
                </property>
            </properties>
        </section>
    </properties>
</template>
